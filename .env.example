# Optional: enables Gemini AI task generation in the browser.
# If omitted, the app falls back to built-in rule-based recommendations.
VITE_GEMINI_API_KEY=""

# Optional: custom base path when deploying under a subdirectory.
# Example for GitHub Pages:
# VITE_BASE_PATH="/somnus-cbt-i/"
VITE_BASE_PATH="/somnus-cbt-i/"
